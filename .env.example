# Copy this file to .env for local Docker Compose. Never commit .env.

WEBHOOK_HTTP_PORT=8080
WEBHOOK_PRIVATE_KEY_PATH=./secrets/private.key

AUTOINVENTARIO_API_KEY=replace-with-local-api-key

INVENTORY_PROCESSING_MODE=Local

LICENSE_EDITION=Community/Internal
LICENSE_FILE_PATH=
LICENSE_PUBLIC_KEY_PATH=
LICENSE_ALLOW_UNSIGNED_DEVELOPMENT=true

MANAGEENGINE_BASE_URL=https://manageengine.example.local
MANAGEENGINE_WORKSTATIONS_PATH=/api/v3/workstations
MANAGEENGINE_TIMEOUT_SECONDS=10
MANAGEENGINE_API_TOKEN=replace-with-manageengine-token

POSTGRES_DB=autoinventario
POSTGRES_USER=autoinventario
POSTGRES_PASSWORD=replace-with-postgres-password
